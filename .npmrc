# NPM Security Configuration (root)
# Prevent supply chain attacks per: https://www.trendmicro.com/en_us/research/25/i/npm-supply-chain-attack.html

# Require package-lock.json to match package.json
package-lock=true

# Only allow packages from official npm registry
registry=https://registry.npmjs.org/

# Verify package integrity using checksums
audit=true
audit-level=moderate

# Prevent automatic execution of lifecycle scripts from dependencies
ignore-scripts=false

# Engine strict - fail if Node/NPM version doesn't match
engine-strict=true

# Save exact versions (no ^ or ~)
save-exact=true
