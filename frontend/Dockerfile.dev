# Development Dockerfile for Frontend
FROM node:22-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies (use mirror as fallback if main registry fails)
RUN npm install --registry https://registry.npmmirror.com || npm install

# Copy application
COPY . .

# Expose port
EXPOSE 3000

# Run development server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
