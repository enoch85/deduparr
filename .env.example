# Deduparr Environment Configuration

# User/Group IDs (run 'id' to find yours)
PUID=1000
PGID=1000
UMASK=002

# Timezone (e.g., America/New_York, Europe/London, etc.)
TZ=Etc/UTC

# Database Configuration
DATABASE_TYPE=sqlite
# For SQLite (default):
DATABASE_URL=sqlite:////config/deduparr.db
# For PostgreSQL (uncomment postgres service in docker-compose.yml):
# DATABASE_URL=postgresql+asyncpg://deduparr:deduparr@postgres:5432/deduparr

# Web UI Port
UI_PORT=8655

# Paths
CONFIG_PATH=./config
DATA_PATH=./data

# Media Path (read-write access to your media files)
# This should match your Plex/Radarr/Sonarr media paths
MEDIA_PATH=/path/to/media

# Optional: Log Level
LOG_LEVEL=INFO

# Optional: Scheduled Scans
# Set ENABLE_SCHEDULED_SCANS=true to automatically scan for duplicates
# SCAN_INTERVAL_HOURS controls how often scans run (default: 24 hours)
ENABLE_SCHEDULED_SCANS=false
SCAN_INTERVAL_HOURS=24

# Optional: API rate limiting
# API_RATE_LIMIT=100
